{
  "configs": [
    {
      "name": "canbus",
      "port": 6001,
      "host": "localhost"
    },
    {
      "name": "filter",
      "port": 20001,
      "host": "localhost"
    },
    {
      "name": "track_follower",
      "port": 20101,
      "host": "localhost",
      "subscriptions": [
        {
          "uri": {
            "path": "/state",
            "query": "service_name=track_follower"
          },
          "every_n": 1
        }
      ],
      "log_level": "INFO"
    },
    {
      "name": "oak/0",
      "port": 50010,
      "host": "localhost"
    },
    {
      "name": "oak/1",
      "port": 50010,
      "host": "localhost"
    },
    {
      "name": "multi_subscriber",
      "subscriptions": [
        {
          "uri": {
            "path": "*",
            "query": "service_name=canbus"
          },
          "every_n": 1
        },
        {
          "uri": {
            "path": "*",
            "query": "service_name=filter"
          },
          "every_n": 1
        },
        {
          "uri": {
            "path": "*",
            "query": "service_name=track_follower"
          },
          "every_n": 1
        }
      ]
    }
  ]
